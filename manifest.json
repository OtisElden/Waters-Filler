{
  "manifest_version": 3,
  "name": "Waters filler",
  "description": "Designed to auto fill temmplates and values for narritive",
  "version": "1.3.1",

  "icons": {

    "16": "WHITE.png"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [ "https://wyoming.imagetrendelite.com/*" ],
      "js": [ "contentScript.js", "tesseractContentScript.js", "tesseractJS/scripts/tesseract.min.js" ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },

  "web_accessible_resources": [
    {
      "resources": [ "suggestions.json", "tesseractJS/scripts/*", "tesseractJS/images/*" ],
      "matches": [ "https://wyoming.imagetrendelite.com/*" ]
    }
  ]
} 